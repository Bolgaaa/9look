# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_CALLBACK_URL=https://your-app.railway.app/auth/discord/callback

# Session
SESSION_SECRET=your_super_secret_session_key_change_this

# App
PORT=3000
NODE_ENV=production
APP_URL=https://your-app.railway.app

# Optional: Discord server ID to restrict access (leave empty for all)
DISCORD_GUILD_ID=

# API Keys (fill in your own)
# LEAKCHECK_API_KEY=
# DEHASHED_API_KEY=
# HUNTER_API_KEY=
# INTELX_API_KEY=
# HAVEIBEENPWNED_API_KEY=
